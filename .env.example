# ============================================
# CONFIGURACION DE PROVEEDORES DE IA
# ============================================

# Seleccionar proveedor activo: deepseek, openai, anthropic
NEXT_PUBLIC_ACTIVE_PROVIDER=deepseek

# --------------------------------------------
# DEEPSEEK
# --------------------------------------------
DEEPSEEK_API_KEY=

# --------------------------------------------
# OPENAI (para GPT-4 Vision)
# --------------------------------------------
OPENAI_API_KEY=

# --------------------------------------------
# ANTHROPIC (Claude Vision)
# --------------------------------------------
ANTHROPIC_API_KEY=

# ============================================
# BASE DE DATOS
# ============================================

# PostgreSQL connection string (con schema demo_deepsek_dev)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/deepseek_chat?schema=demo_deepsek_dev"

# JWT secret para tokens de autenticacion
JWT_SECRET=cambia-este-valor-por-un-secreto-seguro

# --------------------------------------------
# Configuracion avanzada (opcional)
# --------------------------------------------
# NEXT_PUBLIC_BASE_URL=https://api.deepseek.com/chat/completions
